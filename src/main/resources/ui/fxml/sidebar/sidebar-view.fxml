<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml/1" spacing="10" styleClass="vbox" xmlns="http://javafx.com/javafx/23.0.1"

      prefHeight="397.0" prefWidth="200.0">
    <padding>
        <Insets top="10" left="10" right="10"/>
    </padding>
    <spacing>10</spacing>

    <Button text="➕ Crear Namespace"
            fx:id="createNamespaceButton"/>

    <Button text="Agregar Credenciales"
            fx:id="addCredentialsButton"
    />

    <Separator orientation="HORIZONTAL" style="-fx-background-color:#4E5254;"/>
    <TreeView fx:id="treeView" styleClass="treeView"/>
</VBox>
