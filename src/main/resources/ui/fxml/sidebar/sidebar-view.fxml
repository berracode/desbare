<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/23.0.1"
      fx:controller="co.com.bancolombia.desbare.ui.controller.sidebar.SidebarController"
      stylesheets="@../../css/sidebar/sidebar.css"
      spacing="12"
      styleClass="vbox"
      prefHeight="397.0"
      prefWidth="200.0">
    <padding>
        <Insets top="20" right="12" bottom="20" left="12"/>
    </padding>

    <Label text="Herramientas" styleClass="sidebar-title"/>
    <Separator orientation="HORIZONTAL"/>

    <Button fx:id="btnGpg" maxWidth="Infinity" text="GPG" styleClass="tool-button"
            onAction="#handleOpenGpg"/>
    <Button fx:id="btnBase64" maxWidth="Infinity" text="Base64" styleClass="tool-button"
            onAction="#handleOpenBase64"/>
</VBox>