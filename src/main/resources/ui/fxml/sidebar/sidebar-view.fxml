<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.com.bancolombia.desbare.ui.controller.sidebar.SidebarController"
      stylesheets="@../../css/sidebar/sidebar.css" spacing="15" styleClass="vbox"
      xmlns="http://javafx.com/javafx/23.0.1"
      prefHeight="397.0" prefWidth="200.0">
    <padding>
        <Insets top="20" right="10" bottom="20" left="10"/>
    </padding>
    <spacing>10</spacing>
    <Label text="Herramientas" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
    <Separator orientation="HORIZONTAL" style="-fx-opacity: 0.4;"/>

    <Button fx:id="btnGpg" maxWidth="Infinity" text="GPG" style="-fx-background-color: #57606f;-fx-text-fill: white;"
            onAction="#handleOpenGpg"/>
    <Button fx:id="btnBase64" maxWidth="Infinity" text="Base64"
            style="-fx-background-color: #57606f;-fx-text-fill: white;" onAction="#handleOpenBase64"/>
</VBox>
