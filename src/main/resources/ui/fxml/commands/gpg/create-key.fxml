<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx"
      spacing="15"
      style="-fx-background-color: #2B2B2B;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Generar Llave Pública"
           style="-fx-text-fill:white;-fx-font-size:18px;-fx-font-weight:bold;"/>

    <GridPane hgap="10" vgap="10">

        <Label text="Nombre:" style="-fx-text-fill:white;" GridPane.rowIndex="0"/>
        <TextField promptText="Juan Hernandez"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="0"/>

        <Label text="Email:" style="-fx-text-fill:white;"
               GridPane.rowIndex="1"/>
        <TextField promptText="usuario@correo.com"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="1"/>

        <Label text="Passphrase:"
               style="-fx-text-fill:white;"
               GridPane.rowIndex="2"/>
        <PasswordField
                GridPane.columnIndex="1"
                GridPane.rowIndex="2"/>

    </GridPane>

    <Button text="Generar Llave"/>
</VBox>