<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/23.0.1"
      spacing="14"
      styleClass="tab-content-area"
      fx:controller="com.ritallus.desvare.ui.controller.commands.gpg.ListKeysController">

    <padding>
        <Insets top="20" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Llaves GPG" styleClass="sidebar-title"/>

    <HBox spacing="10">
        <Button text="Refrescar" styleClass="btn-secondary" onAction="#handleRefresh"/>
        <Button text="Copiar Llave" styleClass="btn-secondary" onAction="#handleCopyPublicKey"/>
        <Button text="Exportar" styleClass="btn-secondary" onAction="#handleExport"/>
        <Button text="Eliminar" styleClass="btn-secondary" onAction="#handleByDelete"/>
    </HBox>

    <TableView fx:id="tblKeys" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="Id / Fingerprint" prefWidth="180"/>
            <TableColumn fx:id="colPublicKey" text="Llave pública (Base64)" prefWidth="220"/>
            <TableColumn fx:id="colName" text="Nombre" prefWidth="150"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
            <TableColumn fx:id="colCreatedAt" text="Creación" prefWidth="150"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>