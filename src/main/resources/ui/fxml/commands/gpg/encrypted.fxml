<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/23.0.1"
      spacing="14"
      styleClass="tab-content-area"
      fx:controller="co.com.bancolombia.desbare.ui.controller.commands.gpg.EncryptController">

    <padding>
        <Insets top="20" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Cifrar Texto" styleClass="sidebar-title"/>

    <TextField fx:id="txtRecipient" promptText="Email o identificador de la llave pública"/>

    <TextArea fx:id="txtPlainText" promptText="Texto a cifrar"
              prefHeight="180" VBox.vgrow="ALWAYS"/>

    <Button onAction="#handleEncrypt" text="Cifrar" styleClass="btn-primary" maxWidth="150"/>

    <TextArea fx:id="txtEncrypted" promptText="Resultado cifrado"
              editable="false"
              prefHeight="180" VBox.vgrow="ALWAYS"/>
</VBox>