<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx"
      spacing="12"
      style="-fx-background-color:#2B2B2B;"
      fx:controller="co.com.bancolombia.desbare.ui.controller.commands.gpg.EncryptController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Cifrar Texto"
           style="-fx-text-fill:white;-fx-font-size:18px;-fx-font-weight:bold;"/>

    <TextField fx:id="txtRecipient" promptText="Email o identificador de la llave pública"/>

    <TextArea fx:id="txtPlainText" promptText="Texto a cifrar"
              prefHeight="180"/>

    <Button onAction="#handleEncrypt" text="Cifrar"/>

    <TextArea fx:id="txtEncrypted" promptText="Resultado cifrado"
              editable="false"
              prefHeight="180"/>
</VBox>