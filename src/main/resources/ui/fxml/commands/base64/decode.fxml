<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/23.0.1"
      spacing="14"
      styleClass="tab-content-area"
      fx:controller="co.com.bancolombia.desbare.ui.controller.commands.base64.DecodeController">

    <padding>
        <Insets top="20" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Decodificar Base64" styleClass="sidebar-title"/>

    <TextArea fx:id="txtInputBase64" promptText="Ingresa el texto en base64"
              prefHeight="180" VBox.vgrow="ALWAYS"/>

    <Button onAction="#handleDecode" text="Decodificar" styleClass="btn-primary" maxWidth="150"/>

    <TextArea fx:id="txtOutputText" promptText="Resultado decodificado..."
              editable="false"
              prefHeight="180" VBox.vgrow="ALWAYS"/>
</VBox>