<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/23.0.1"
            fx:controller="co.com.bancolombia.desbare.ui.controller.commands.base64.Base64Controller"
            stylesheets="@../../../css/global.css"
            prefHeight="720.0" prefWidth="1000.0">

    <VBox AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">

        <TabPane fx:id="commandTabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 VBox.vgrow="ALWAYS">

            <Tab text="Codificar"/>
            <Tab text="Decodificar"/>
        </TabPane>
    </VBox>
</AnchorPane>