<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/23.0.1"
      spacing="14"
      styleClass="tab-content-area"
      fx:controller="com.ritallus.desvare.ui.controller.commands.base64.EncodeController">

    <padding>
        <Insets top="20" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Codificar en Base64" styleClass="sidebar-title"/>

    <TextArea fx:id="txtInputText" promptText="Ingresa el texto plano o datos a codificar..."
              prefHeight="180" VBox.vgrow="ALWAYS"/>

    <Button onAction="#handleEncode" text="Codificar" styleClass="btn-primary" maxWidth="150"/>

    <TextArea fx:id="txtOutputBase64" promptText="Resultado codificado en Base64..."
              editable="false"
              prefHeight="180" VBox.vgrow="ALWAYS"/>
</VBox>